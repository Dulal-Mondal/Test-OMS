// Prisma schema — Test OMS
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Order {
  id            String   @id @default(uuid())

  sourceOrderId String   @unique @map("source_order_id")
  source        String   @default("SoftBrainChat")
  platform      String?

  // Customer
  customerName    String  @map("customer_name")
  customerPhone   String  @map("customer_phone")
  customerAddress String  @map("customer_address")

  // Product
  productName     String  @map("product_name")
  productCode     String? @map("product_code")      // ← নতুন
  productPrice    String? @map("product_price")
  productSize     String? @map("product_size")      // ← নতুন
  productQuantity Int     @default(1) @map("product_quantity")
  productImage    String? @map("product_image")     // ← নতুন (image URL)

  status        OrderStatus @default(PENDING)
  notes         String?

  syncedBack    Boolean  @default(false) @map("synced_back")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("orders")
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
